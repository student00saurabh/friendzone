<% layout("/layouts/boilerplate") -%>
<div class="row mt-3 full-height">
  	<div class="col-12 col-md-6 ">
    	<div class="card" data-aos="fade-right" data-aos-duration="800">
      		<% if(post.owner){ %>
				<a class="post-owner-card" href="/profile/<%= post.owner._id %>"><img src="<%= post.owner.image.url %>" alt="profile" class="profile-image"><%= post.owner.username %></a>
			<% } %>
			<img src="<%= post.image.url %>" class="card-img-top show-img" alt="listing_image">
  			<div class="card-body">
			<p class="card-text"><%= post.description %></p>
			<div class="btns">
			<%
  				let likeUser = null;
  				let alreadyLiked = post.likes.some((like) => {
    			if (currUser && like.cliker == currUser._id) {
      				likeUser = like; // store the like object
      				return true;
    			}
    			return false;
  				});
			%>
				<% if(currUser && (!alreadyLiked)){%>
					<form action="/posts/<%= post._id %>/likes" class="like-unlike-form mb-3" method="post">
						<button class="like-button prevent-multi-submit" type="submit"><i class="fa-regular fa-heart" id="icon"></i></button>
							<%= post.likes.length %>
					</form>
				<% } %>
						
				<% if(currUser && alreadyLiked ) { %>
					<form action="/posts/<%= post._id %>/likes/<%= likeUser._id %>?_method=DELETE" class="like-unlike-form mb-3" method="post">
						<button class="like-button prevent-multi-submit" type="submit"><i class="fa-solid fa-heart unlike-heart"></i></button>
							<%= post.likes.length %>
					</form>
				<% } %>
				<% if(currUser && currUser._id.equals(post.owner._id)) { %>
						<a href="/posts/<%= post._id %>/edit" class="btn btn-sm btn-dark offset-1 edit-btn">Edit</a>
						<form method="POST" action="/posts/<%= post._id %>?_method=DELETE">
							<button class="btn btn-sm btn-dark offset-3 prevent-multi-submit">Delete</button>
						</form>
					 
				<% } %>
				<span class="time-date">
					<%= new Date(post.createdAt).toLocaleString() %>
				</span>
			</div>
			</div>
    	</div>
  	</div>
  	<div class="col-12 col-md-6 mobile-half-height second-card">
    	<div class="card h-100" data-aos="fade-left" data-aos-duration="800">
			<div class="card-body scrollable-content">
      			<% if(currUser) { %>
					<h4>Leave a Comment</h4>
					<form action="/posts/<%= post.id %>/comments" method="POST" novalidate class="needs-validation">
						<div class="mb-3 mt-3">
							<label for="content" class="form-label">Comment</label>
							<input type="text" name="comment[content]" id="cntent" cols="30" rows="5" class="form-control" required>
							<div class="invalid-feedback">Please submit some comments for review.</div>
						</div>
						<button class="btn btn-outline-dark prevent-multi-submit">Submit</button>
					</form>
				<% } %>

				<% if(post.comments.length > 0){ %>
					<div class="row">
						<p><b>All Comments</b></p>
						<% for(comment of post.comments) {%>
							<div class="card comment-card col-10 ms-4 mb-3">
								<div class="card-body comment-card-body">
									<h5 class="card-title"><img src="<%= comment.author.image.url %>" alt="profile" class="profile-image"><%= comment.author.username %></h5>
									<p class="card-text"><%= comment.content %></p>
									<p class="card-text">Date: <%= comment.createdAt.toISOString().split('T')[0] %></p>
									<% if(currUser && currUser._id.equals(comment.author._id)) { %>
										<form action="/posts/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" class="mb-3" method="post">
											<button class="btn btn-sm btn-dark comment-btn prevent-multi-submit">Delete</button>
										</form>
									<% } %>
								</div>
							</div>
						<% } %>
					</div>
				<% } %>
				
    		</div>
		</div>
  	</div>
</div>
