<% layout("/layouts/boilerplate") -%>
<h1 class="col-6 offset-3">Login</h1>

<div class="row mt-3">
    <div class="col-12 col-md-6 offset-md-3">
        <div class="signup-form">
        <form action="/login" method="POST" class="needs-validation" novalidate>
            <!-- username -->
			<div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input
                    type="text"
					id="username"
                    name="username"
                    class="form-control"
                    required>
                </div>

				<!-- password -->
				 <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input
                    type="password"
					id="password"
                    name="password"
                    class="form-control"
                    required>
                </div>
				<button class="btn btn-success">Login</button><br>
            </form>
           <p>Create new account! <a href="/signup" class="posts-link"><button class="btn btn-sm btn-outline-success" style="color: #fff !important">signup</button></a></p>
            </div>
        </div>
    </div> 