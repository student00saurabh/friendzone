<% layout("/layouts/boilerplate") -%>

<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="space-y-6">
        
        <!-- Profile Card -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden" data-aos="fade-down" data-aos-duration="800">
            
            <!-- Cover Image Area (Optional) -->
            <div class="h-32 bg-gradient-to-r from-purple-600 to-pink-600"></div>
            
            <!-- Profile Image -->
            <div class="relative px-6">
                <div class="-mt-16 mb-4">
                    <img src="<%= profile.image.url %>" class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover mx-auto md:mx-0" alt="<%= profile.username %>">
                </div>
            </div>
            
            <!-- Profile Info -->
            <div class="px-6 pb-6">
                <div class="text-center md:text-left">
                    <h2 class="text-2xl font-bold text-gray-800"><%= profile.username %></h2>
                    
                    <div class="mt-4 space-y-2">
                        <div class="flex flex-wrap items-center gap-2 text-gray-600">
                            <i class="fa-solid fa-envelope w-5 text-purple-500"></i>
                            <span class="font-medium">Email:</span>
                            <span><%= profile.email %></span>
                        </div>
                        
                        <div class="flex flex-wrap items-center gap-2 text-gray-600">
                            <i class="fa-solid fa-venus-mars w-5 text-purple-500"></i>
                            <span class="font-medium">Gender:</span>
                            <span><%= profile.gender %></span>
                        </div>
                        
                        <div class="flex flex-wrap items-center gap-2 text-gray-600">
                            <i class="fa-solid fa-cake-candles w-5 text-purple-500"></i>
                            <span class="font-medium">Age:</span>
                            <span><%= profile.age %></span>
                        </div>
                        
                        <div class="flex flex-wrap items-start gap-2 text-gray-600">
                            <i class="fa-solid fa-address-card w-5 text-purple-500 mt-1"></i>
                            <span class="font-medium">About:</span>
                            <span class="flex-1"><%= profile.about %></span>
                        </div>
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="mt-6">
                        <% if(!profile._id.equals(currUser._id)){ %>
                            <form action="/inbox/<%= profile._id %>" method="get">
                                <button type="submit" class="prevent-multi-submit w-full md:w-auto px-6 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-lg font-semibold hover:from-purple-700 hover:to-pink-700 transition-all duration-200 shadow-md hover:shadow-lg">
                                    <i class="fa-solid fa-message mr-2"></i>
                                    Message to <%= profile.username %>
                                </button>
                            </form>
                        <% } else { %>
                            <a href="/logout" class="inline-block w-full md:w-auto px-6 py-2 bg-red-500 text-white rounded-lg font-semibold hover:bg-red-600 transition-all duration-200 text-center">
                                <i class="fa-solid fa-sign-out-alt mr-2"></i>
                                Logout
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- User's Posts Section -->
        <div>
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <i class="fa-solid fa-newspaper text-purple-500 mr-2"></i>
                Posts by <%= profile.username %>
                <span class="ml-2 text-sm text-gray-500">(<%= posts.length %> posts)</span>
            </h3>
            
            <div class="space-y-4">
                <% for(post of posts){ %>
                <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300" data-aos="fade-left" data-aos-duration="800">
                    
                    <!-- Post Image Link -->
                    <a href="/posts/<%= post._id %>">
                        <img src="<%= post.image.url %>" class="w-full h-64 md:h-80 object-cover hover:opacity-90 transition-opacity duration-300" alt="post_image">
                    </a>
                    
                    <!-- Post Body -->
                    <div class="p-4">
                        <p class="text-gray-800 font-medium mb-3">
                            <i class="fa-solid fa-quote-left text-purple-400 mr-1"></i>
                            <%= post.description %>
                        </p>
                        
                        <!-- Like and Comment Actions -->
                        <div class="flex items-center space-x-4 pt-3 border-t border-gray-100">
                            <%
                                let likeUser = null;
                                let alreadyLiked = post.likes.some((like) => {
                                    if (currUser && like.cliker == currUser._id) {
                                        likeUser = like;
                                        return true;
                                    }
                                    return false;
                                });
                            %>
                            
                            <% if(currUser && (!alreadyLiked)){ %>
                                <form action="/posts/<%= post._id %>/likes" method="post" class="inline">
                                    <button type="submit" class="like-button flex items-center space-x-1 text-gray-500 hover:text-purple-600 transition-colors duration-200">
                                        <i class="fa-regular fa-heart text-xl"></i>
                                        <span><%= post.likes.length %></span>
                                    </button>
                                </form>
                            <% } %>
                            
                            <% if(currUser && alreadyLiked ) { %>
                                <form action="/posts/<%= post._id %>/likes/<%= likeUser._id %>?_method=DELETE" method="post" class="inline">
                                    <button type="submit" class="like-button flex items-center space-x-1 text-red-500 hover:text-red-600 transition-colors duration-200">
                                        <i class="fa-solid fa-heart text-xl"></i>
                                        <span><%= post.likes.length %></span>
                                    </button>
                                </form>
                            <% } %>
                            
                            <a href="/posts/<%= post._id%>" class="flex items-center space-x-1 text-gray-500 hover:text-purple-600 transition-colors duration-200">
                                <i class="fa-regular fa-comment text-xl"></i>
                                <span>Comments</span>
                            </a>
                        </div>
                    </div>
                </div>
                <% } %>
                
                <!-- No Posts Message -->
                <% if(posts.length === 0) { %>
                <div class="bg-white rounded-xl shadow-md p-8 text-center">
                    <i class="fa-solid fa-camera-retro text-5xl text-gray-300 mb-3"></i>
                    <p class="text-gray-500">No posts yet</p>
                </div>
                <% } %>
            </div>
        </div>
        
    </div>
</div>

<style>
    .like-button {
        background: none;
        border: none;
        cursor: pointer;
    }
    
    .like-button:active {
        transform: scale(0.95);
    }
</style>