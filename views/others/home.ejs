<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Welcome - FriendZone</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(to right, #4B9EB4, #B44B9E);
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .welcome-card {
      background-color: #fff;
      color: #4B9EB4;
      border-radius: 20px;
      padding: 40px 30px;
      box-shadow: 0 0 15px rgba(0,0,0,0.1);
      text-align: center;
      max-width: 400px;
      width: 90%;
    }
    .welcome-card h1 {
      font-weight: bold;
      margin-bottom: 20px;
    }
    .welcome-card p {
      color: #555;
    }
    .btn-login {
      background-color: #4B9EB4;
      color: white;
    }
    .btn-signup {
      background-color: #B44B9E;
      color: white;
    }
    .btn-login:hover,
    .btn-signup:hover {
      opacity: 0.9;
    }
  </style>
</head>
<body>

  <div class="welcome-card">
    <h1>Welcome to FriendZone</h1>
    <p>Connect, chat, and stay in touch with your friends.</p>
    <div class="d-grid gap-2 mt-4">
      <a href="/login" class="btn btn-login btn-lg">Login</a>
      <a href="/signup" class="btn btn-signup btn-lg">Sign Up</a>
    </div>
  </div>

</body>
</html>
